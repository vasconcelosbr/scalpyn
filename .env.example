# ============================================================
# Scalpyn — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================

# ── Backend (FastAPI / Cloud Run) ───────────────────────────

# PostgreSQL / TimescaleDB connection string
# Cloud SQL (Unix socket): postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# Direct TCP:              postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://scalpyn:scalpyn@localhost:5432/scalpyn

# Redis connection string (Memorystore or external Redis)
REDIS_URL=redis://localhost:6379/0

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-a-strong-random-value-at-least-32-chars

# AES key used to encrypt exchange API credentials at rest (generate with: openssl rand -hex 16)
ENCRYPTION_KEY=replace-with-a-random-32-hex-char-value-here

# ── Frontend (Next.js / Vercel) ──────────────────────────────

# Server-side URL of the backend API used by the Next.js proxy (never exposed to the browser).
# Set this to the base URL of your backend service — with or without a trailing /api suffix,
# both are handled correctly by the proxy.
# In local development this defaults to http://localhost:8000 when not set.
# Set this in your hosting environment (e.g. Vercel) when the frontend and backend
# are deployed as separate services.
# Example (Cloud Run): https://scalpyn-api-xxxxxx-uc.a.run.app
BACKEND_URL=http://localhost:8000

# Public URL of the backend API, including the /api path prefix.
# Only needed when the frontend and backend are on different domains in production
# and the Next.js rewrite proxy alone is not sufficient (e.g. Vercel + separate API domain).
# Leave this unset for local development — the rewrite proxy will handle routing to BACKEND_URL.
# Example (Cloud Run): NEXT_PUBLIC_API_URL=https://scalpyn-backend-xxxxxx-rj.a.run.app/api
# Example (custom domain): NEXT_PUBLIC_API_URL=https://api.scalpyn.com/api
# NEXT_PUBLIC_API_URL=
