# ============================================================
# Scalpyn — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================

# ── Backend (FastAPI / Cloud Run) ───────────────────────────

# PostgreSQL / TimescaleDB connection string
# Cloud SQL (Unix socket): postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# Direct TCP:              postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://scalpyn:scalpyn@localhost:5432/scalpyn

# Redis connection string (Memorystore or external Redis)
REDIS_URL=redis://localhost:6379/0

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-a-strong-random-value-at-least-32-chars

# AES key used to encrypt exchange API credentials at rest (generate with: openssl rand -hex 16)
ENCRYPTION_KEY=replace-with-a-random-32-hex-char-value-here

# ── Frontend (Next.js / Vercel) ──────────────────────────────

# Public URL of the backend API, including the /v1 path prefix if applicable.
# Example (Cloud Run): https://scalpyn-backend-xxxxxx-rj.a.run.app/api
# Example (custom domain): https://api.scalpyn.com/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api
