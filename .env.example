# ============================================================
# Scalpyn — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.
# ============================================================

# ── PostgreSQL / TimescaleDB ─────────────────────────────────
# Credentials used by the db container and all backend services.
POSTGRES_USER=scalpyn
POSTGRES_PASSWORD=scalpyn
POSTGRES_DB=scalpyn
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend (FastAPI) ─────────────────────────────────────────
# Full database URL consumed by SQLAlchemy (asyncpg driver).
# In docker-compose this is built automatically from POSTGRES_* vars.
# Override only when connecting to an external DB.
# DATABASE_URL=postgresql+asyncpg://scalpyn:scalpyn@db:5432/scalpyn

# Full Redis URL consumed by Celery and the cache layer.
# REDIS_URL=redis://redis:6379/0

# Port the backend FastAPI app listens on (inside the container: always 8000).
BACKEND_PORT=8000

# How many uvicorn workers to spin up (1 is fine for local dev).
WEB_CONCURRENCY=2

# Secret used to sign JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# AES-128 key (32 hex chars) used to encrypt Gate.io API credentials at rest.
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Gate.io API credentials ───────────────────────────────────
# Leave empty to run in paper-trading / simulation mode.
# The spot and futures engines will refuse to execute live orders
# when these are blank.
GATE_API_KEY=
GATE_API_SECRET=

# ── Frontend (Next.js) ────────────────────────────────────────
# Port the Next.js dev/prod server listens on.
FRONTEND_PORT=3000

# Node environment: development | production
NODE_ENV=development

# Server-side URL the Next.js proxy uses to forward /api/* requests to the
# backend. In docker-compose this is always http://backend:8000.
# Override when the frontend is deployed separately (e.g. Vercel).
BACKEND_URL=http://backend:8000

# Public URL of the backend API (exposed to the browser).
# Required in production when frontend and backend are on different domains.
# Leave empty for local development — the Next.js proxy handles it.
# Example: NEXT_PUBLIC_API_URL=https://api.scalpyn.com
NEXT_PUBLIC_API_URL=
