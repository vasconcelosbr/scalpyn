{"nodes": [{"id": "runbook_celery_queue_topology", "label": "Runbook: Celery Queue Topology", "file_type": "document", "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "queue_split_rationale", "label": "Three-Queue Split Design Rationale", "file_type": "rationale", "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Before split, a single Celery queue caused two real incidents: (1) slow compute_indicators blocked evaluate_signals for full duration, causing late buys and missed force-close; (2) simulation burst of 30k items pushed pipeline_scan ticks 12 minutes late. Three queues give execution its own isolated workers."}, {"id": "task_dedup_wrapper", "label": "Task Dedup Wrapper (SET NX EX via Redis)", "file_type": "rationale", "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All Celery enqueues inside app/tasks/ must go through task_dispatch.enqueue(). Wrapper uses Redis SET NX EX; duplicate dropped with DEDUP_SKIP log. Lock released by task_postrun signal. Fails open on Redis unreachable."}, {"id": "queue_depth_hysteresis", "label": "Queue Depth + Hysteresis Alert (10k/8k threshold)", "file_type": "rationale", "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Alert at depth>=10000 (ok\u2192alerted), reset at depth<8000. Thresholds sized against simulation burst that defined worst-case queue length without false alerts during normal operation."}], "edges": [{"source": "runbook_celery_queue_topology", "target": "queue_split_rationale", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "queue_split_rationale", "target": "20_celery_topology", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "runbook_celery_queue_topology", "target": "task_dedup_wrapper", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "task_dedup_wrapper", "target": "task_dispatch", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "runbook_celery_queue_topology", "target": "celery_routing_invariants_test", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "queue_depth_hysteresis", "target": "queue_microstructure", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}, {"source": "task_dedup_wrapper", "target": "task_dispatch", "relation": "semantically_similar_to", "confidence": "AMBIGUOUS", "confidence_score": 0.2, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 0.2}, {"source": "runbook_celery_queue_topology", "target": "20_celery_topology", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/runbooks/celery-queue-topology.md", "source_location": null, "weight": 1.0}], "hyperedges": []}